#!/usr/bin/env python3

import sys
import re

# Enforces conventional commit format with proper newlines between sections.
# Requires:
# 1. Header following type(scope): description format
# 2. Body explaining WHY the change was made
# 3. Optional footer with proper spacing
# See docs/rules.md for more details

def main():
    commit_msg_file = sys.argv[1]
    with open(commit_msg_file, 'r') as f:
        commit_msg = f.read()

    # Split message into parts
    parts = commit_msg.strip().split('\n\n')
    header = parts[0].strip() if parts else ''
    body = parts[1].strip() if len(parts) > 1 else ''
    footer = parts[2].strip() if len(parts) > 2 else ''

    # Check header format
    header_pattern = r'^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|security|org)(\([a-z-]+\))?: .+$'
    if not re.match(header_pattern, header):
        print("Error: Commit header must follow format: type(scope): description")
        print("Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert, security, org")
        print("Example: feat(auth): add login handler")
        sys.exit(1)

    # Require body
    if not body:
        print("Error: Commit message must include a body explaining WHY this change is being made")
        print("Separate header from body with a blank line")
        sys.exit(1)

    # If there's a footer, ensure it's separated by newline
    if footer and len(parts) < 3:
        print("Error: Footer must be separated from body by a blank line")
        print("Example format:")
        print("feat(scope): description\n")
        print("Body explaining why...\n")
        print("Refs Story XXX")
        sys.exit(1)

    # Success - message follows format
    sys.exit(0)

if __name__ == '__main__':
    main()
