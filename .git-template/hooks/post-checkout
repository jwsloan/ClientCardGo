#!/usr/bin/env python3

import sys
import subprocess

# Args: previous HEAD, new HEAD, is_branch_checkout
prev_head, new_head, is_branch_checkout = sys.argv[1:]

# Only run on branch checkouts (not file checkouts)
if is_branch_checkout != '1':
    sys.exit(0)

# Check if go.sum changed
cmd = ['git', 'diff', '--name-only', prev_head, new_head]
changes = subprocess.check_output(cmd).decode().strip()

if 'go.sum' not in changes:
    sys.exit(0)

print("\n📦 go.sum changed, running security audit...")
try:
    subprocess.run(['nancy', 'go.sum'], check=True)
except subprocess.CalledProcessError:
    print("⚠️  Warning: Security vulnerabilities found in dependencies")
    print("    Run 'nancy go.sum' for details")

# Don't block the checkout, but warn if audit fails
sys.exit(0)
